<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat" Height="450" Width="400">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="UsernameBox" Width="100" Margin="0,0,10,0"/>
            <TextBox x:Name="MessageBox" Width="200"/>
            <Button Content="Send" Width="60" Click="Send_Click"/>
        </StackPanel>

        <ListBox x:Name="ChatList" Grid.Row="1" Margin="0,10,0,10"/>

    </Grid>
</Window>